# Used by docker-compose.yml to configure the stack.
# Copy this file to .env before running:
#   docker compose --env-file .env pull
#   docker compose --env-file .env up -d
#
# Images are built, scanned, and pushed to GHCR by
# .github/workflows/development.yml, then promoted to production by
# .github/workflows/production.yml — this stack pulls, it doesn't build
# locally. See BACKEND_IMAGE / FRONTEND_IMAGE below.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urlshortener
POSTGRES_PORT=5432

# Backend
# BASE_URL is used to build short URLs shown to users, so it must match
# the public, browser-facing scheme (Cloudflare terminates HTTPS in front
# of this origin, so visitors always see https://).
BASE_URL=https://go2url.xyz
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# FRONTEND_URL is used for CORS and must match the Origin header the
# browser actually sends, which is https:// once Cloudflare is in front.
FRONTEND_URL=https://go2url.xyz

# Frontend (baked into the browser bundle at build time)
# Must be https:// — the browser calls this URL directly, and a page
# served over https:// cannot make plain http:// requests (mixed content).
NEXT_PUBLIC_API_URL=https://go2url.xyz

# Nginx (public entrypoint)
NGINX_PORT=80

# Images to pull (pushed by CI, tagged with the released commit SHA).
# Override only if you're pointing at a different registry/tag than the
# workflow default (":prod").
# BACKEND_IMAGE=ghcr.io/kamaljit87/url-shortner-app-backend:prod
# FRONTEND_IMAGE=ghcr.io/kamaljit87/url-shortner-app-frontend:prod
