# Used by docker-compose.yml to configure the stack.
# Copy this file to .env before running `docker compose up`.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urlshortener
POSTGRES_PORT=5432

# Backend (internal to the Docker network; reached only via Nginx)
BASE_URL=http://go2url.xyz
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://go2url.xyz

# Frontend (baked into the browser bundle at build time)
NEXT_PUBLIC_API_URL=http://go2url.xyz

# Nginx (public entrypoint)
NGINX_PORT=80
