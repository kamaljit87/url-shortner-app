# Used by docker-compose.dev.yml to configure the dev stack.
# Copy this file to .env.dev on the server before running:
#   docker compose --env-file .env.dev -f docker-compose.dev.yml pull
#   docker compose --env-file .env.dev -f docker-compose.dev.yml up -d
#
# Images are built and pushed to GHCR by .github/workflows/development.yml
# on every push to the development branch — this stack pulls, it doesn't
# build locally. See DEV_BACKEND_IMAGE / DEV_FRONTEND_IMAGE below.

# PostgreSQL
DEV_POSTGRES_USER=postgres
DEV_POSTGRES_PASSWORD=postgres
DEV_POSTGRES_DB=urlshortener_dev
DEV_POSTGRES_PORT=5433

# Backend
# BASE_URL is used to build short URLs shown to users, so it must match
# the public, browser-facing scheme (Cloudflare terminates HTTPS in front
# of this origin, so visitors always see https://).
DEV_BASE_URL=https://dev.go2url.xyz
DEV_JWT_SECRET=replace-with-a-long-random-secret
DEV_JWT_EXPIRES_IN=7d
# FRONTEND_URL is used for CORS and must match the Origin header the
# browser actually sends, which is https:// once Cloudflare is in front.
DEV_FRONTEND_URL=https://dev.go2url.xyz

# Nginx (public entrypoint for the dev stack — different host port than
# prod's docker-compose.yml so both stacks can run on the same server)
DEV_NGINX_PORT=8080

# Images to pull (pushed by CI). Override only if you're pointing at a
# different registry/tag than the workflow default (":dev").
# DEV_BACKEND_IMAGE=ghcr.io/kamaljit87/url-shortner-app-backend:dev
# DEV_FRONTEND_IMAGE=ghcr.io/kamaljit87/url-shortner-app-frontend:dev
